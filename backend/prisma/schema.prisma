// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model admin_logs {
  id         String     @id @default(cuid())
  userId     String
  userName   String
  action     String
  targetType TargetType
  targetId   String?
  details    Json?
  ip         String?
  timestamp  DateTime   @default(now())
  users      users      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model content {
  id          String        @id @default(cuid())
  userId      String
  type        ContentType
  title       String
  description String?
  category    String?
  status      ContentStatus @default(ACTIVE)
  views       Int           @default(0)
  likes       Int           @default(0)
  comments    Int           @default(0)
  rating      Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  users       users         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  likeRecords   Like[]
  commentRecords Comment[]
  praises       Praise[]      // Связь с похвалами

  @@map("content")
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  createdAt DateTime @default(now())

  user   users   @relation(fields: [userId], references: [id], onDelete: Cascade)
  content content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId])
  @@index([contentId])
  @@map("likes")
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    users   @relation(fields: [userId], references: [id], onDelete: Cascade)
  content content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([contentId])
  @@index([createdAt])
  @@map("comments")
}

// 👇 МОДЕЛЬ ПОХВАЛ (ИСПРАВЛЕННАЯ)
model Praise {
  id          String        @id @default(cuid())
  fromUserId  String        @map("from_user_id")
  toUserId    String        @map("to_user_id")
  
  // 👇 РАЗНЫЕ ПОЛЯ ДЛЯ РАЗНЫХ ТИПОВ КОНТЕНТА
  contentId      String?    @map("content_id")        // для content (проекты, маркет и т.д.)
  libraryItemId  String?    @map("library_item_id")   // для libraryItem (библиотека)
  
  praiseType  PraiseType    @map("praise_type")
  message     String?
  createdAt   DateTime      @default(now())        @map("created_at")

  // Связи с пользователями
  fromUser    users         @relation("PraiseFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      users         @relation("PraiseToUser", fields: [toUserId], references: [id], onDelete: Cascade)
  
  // 👇 СВЯЗИ С РАЗНЫМИ ТИПАМИ КОНТЕНТА
  content     content?      @relation(fields: [contentId], references: [id], onDelete: SetNull)
  libraryItem libraryItem?  @relation(fields: [libraryItemId], references: [id])

  // Уникальность для разных типов контента
  @@unique([fromUserId, contentId])
  @@unique([fromUserId, libraryItemId])
  
  // Индексы
  @@index([fromUserId])
  @@index([toUserId])
  @@index([contentId])
  @@index([libraryItemId])
  @@index([createdAt])
  
  @@map("praises")
}

// 👇 НОВЫЙ ENUM ДЛЯ ТИПОВ ПОХВАЛ
enum PraiseType {
  GREAT         // 👍 Молодец!
  EXCELLENT     // 👏 Отличная работа!
  MASTER        // 🔨 Мастер золотые руки!
  INSPIRING     // 💫 Вдохновляет!
  CREATIVE      // 🎨 Креативно!
  DETAILED      // 🔍 Детально проработано
  HELPFUL       // 🤝 Полезный совет
  THANKS        // 🙏 Спасибо!
}

// 👇 МОДЕЛЬ ДЛЯ БИБЛИОТЕКИ (СТЕЛЛАЖИ)
model librarySection {
  id          String               @id @default(cuid())
  title       String
  icon        String
  words       String[]             // Для разделения на два слова на стеллаже
  order       Int                  @default(0)
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  // Настройки для стеллажа
  allowedTypes String[]            // ["text", "photo", "drawing", "video", "other"]
  fileExtensions String[]           // [".txt", ".md", ".jpg", ...]
  maxFileSize  Int?                 // в байтах

  // Поля для редактирования и удаления
  createdBy    String               // ID создателя
  updatedBy    String?              // Кто последний редактировал
  editCount    Int                  @default(0)  // Счетчик редактирований
  isDeleted    Boolean              @default(false) // Мягкое удаление
  deletedAt    DateTime?             // Дата удаления
  deletedBy    String?               // Кто удалил

  // Связи
  subsections  librarySubsection[]
  items        libraryItem[]
  creator      users                @relation("section_creator", fields: [createdBy], references: [id])
  lastEditor   users?               @relation("section_last_editor", fields: [updatedBy], references: [id])
  deleter      users?               @relation("section_deleter", fields: [deletedBy], references: [id])

  @@index([createdBy])
  @@index([isDeleted])
  @@map("library_sections")
}

// 👇 МОДЕЛЬ ДЛЯ ПОДРАЗДЕЛОВ
model librarySubsection {
  id          String         @id @default(cuid())
  title       String
  sectionId   String
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Поля для редактирования и удаления
  createdBy   String          // ID создателя
  updatedBy   String?         // Кто последний редактировал
  editCount   Int             @default(0)  // Счетчик редактирований
  isDeleted   Boolean         @default(false) // Мягкое удаление
  deletedAt   DateTime?        // Дата удаления
  deletedBy   String?          // Кто удалил

  // Связи
  section     librarySection   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  items       libraryItem[]
  creator     users            @relation("subsection_creator", fields: [createdBy], references: [id])
  lastEditor  users?           @relation("subsection_last_editor", fields: [updatedBy], references: [id])
  deleter     users?           @relation("subsection_deleter", fields: [deletedBy], references: [id])

  @@index([sectionId])
  @@index([createdBy])
  @@index([isDeleted])
  @@map("library_subsections")
}

// 👇 МОДЕЛЬ ДЛЯ ДОКУМЕНТОВ
model libraryItem {
  id             String           @id @default(cuid())
  title          String
  content        String           @db.Text
  type           String           // "text" | "photo" | "drawing" | "video" | "other"
  date           DateTime         @default(now())
  likes          Int              @default(0)      // Обычные лайки ❤️
  
  // Файловые поля
  fileName       String?
  fileSize       Int?             // в байтах
  fileType       String?
  fileUrl        String?          // URL для доступа к файлу
  thumbnail      String?          // URL превью
  url            String?          // Внешняя ссылка

  // Статистика
  views          Int              @default(0)

  // Поля для редактирования и удаления
  createdBy      String           // ID создателя (authorId)
  updatedBy      String?          // Кто последний редактировал
  editCount      Int              @default(0)  // Счетчик редактирований
  isDeleted      Boolean          @default(false) // Мягкое удаление
  deletedAt      DateTime?         // Дата удаления
  deletedBy      String?           // Кто удалил

  // Связи
  sectionId      String
  subsectionId   String
  section        librarySection     @relation(fields: [sectionId], references: [id])
  subsection     librarySubsection  @relation(fields: [subsectionId], references: [id])
  creator        users              @relation("item_creator", fields: [createdBy], references: [id])
  lastEditor     users?             @relation("item_last_editor", fields: [updatedBy], references: [id])
  deleter        users?             @relation("item_deleter", fields: [deletedBy], references: [id])
  praises        Praise[]           // Связь с похвалами (8 эмоций)

  // Индексы для быстрого поиска
  @@index([sectionId])
  @@index([subsectionId])
  @@index([createdBy])
  @@index([type])
  @@index([date])
  @@index([isDeleted])

  @@map("library_items")
}

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("user_notifications")
}

model NotificationSetting {
  id        String   @id @default(cuid())
  userId    String   @unique
  
  emailEnabled   Boolean @default(true)
  emailLikes     Boolean @default(true)
  emailComments  Boolean @default(true)
  emailMessages  Boolean @default(true)
  
  pushEnabled    Boolean @default(false)
  pushLikes      Boolean @default(true)
  pushComments   Boolean @default(true)
  pushMessages   Boolean @default(true)
  
  siteLikes      Boolean @default(true)
  siteComments   Boolean @default(true)
  siteMessages   Boolean @default(true)
  
  quietHours     Boolean @default(false)
  quietStart     Int?
  quietEnd       Int?
  
  updatedAt      DateTime @updatedAt
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

model rating_adjustments {
  id             String   @id @default(cuid())
  userId         String
  reason         String
  ratingChange   Int
  activityChange Int
  adminId        String?
  adminNote      String?
  timestamp      DateTime @default(now())
  users          users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model setting {
  id              String   @id @default(cuid())
  userId          String   @unique
  theme           String   @default("auto")
  brightness      Int      @default(100)
  fontSize        Int      @default(100)
  showAnimations  Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  users users @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("settings")
}

model rule {
  id          String   @id @default(cuid())
  text        String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("rules")
}

model ruleAcceptance {
  id          String   @id @default(cuid())
  userId      String   @unique
  acceptedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rule_acceptances")
}

model marketItem {
  id             String        @id @default(cuid())
  title          String
  description    String
  price          String
  priceValue     Int?
  location       String
  author         String
  authorId       String
  rating         Float         @default(4.5)
  type           ItemType
  imageUrl       String?
  negotiable     Boolean       @default(false)
  expirationDate DateTime?
  duration       DurationType?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  views          Int           @default(0)
  contacts       Int           @default(0)
  category       ItemCategory?
  categoryId     String?
  
  // Поля для модерации
  moderationStatus ModerationStatus @default(PENDING)
  moderationFlags  ModerationFlag[] @default([])
  moderatedAt      DateTime?
  moderatedBy      String?
  moderatorNote    String?

  // Поля для редактирования и удаления
  editCount        Int              @default(0)      // Счетчик редактирований
  lastEditedAt     DateTime?                          // Дата последнего редактирования
  isDeleted        Boolean          @default(false)   // Мягкое удаление
  deletedAt        DateTime?                          // Дата удаления

  users        users           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  marketCategory marketCategory? @relation(fields: [categoryId], references: [id])
  messages     marketMessage[]

  @@map("market_items")
}

model marketCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  icon        String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items marketItem[]

  @@map("market_categories")
}

model marketMessage {
  id         String   @id @default(cuid())
  parentId   String?  
  itemId     String
  fromUserId String
  toUserId   String
  message    String
  read       Boolean  @default(false)
  contactMethod String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt @default(now())

  // Связи
  item     marketItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fromUser users @relation("messages_from", fields: [fromUserId], references: [id])
  toUser   users @relation("messages_to", fields: [toUserId], references: [id])
  
  // Для древовидных ответов
  parent   marketMessage? @relation("MessageReplies", fields: [parentId], references: [id])
  replies  marketMessage[] @relation("MessageReplies")

  // Индексы
  @@index([itemId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([createdAt])
  @@index([parentId])
  
  @@map("market_messages")
}

model users {
  id                 String               @id @default(cuid())
  login              String               @unique
  email              String               @unique
  name               String?
  avatar             String?
  bio                String?
  location           String?
  phone              String?
  role               UserRole             @default(USER)
  isActive           Boolean              @default(true)
  rating             Int                  @default(0)
  activityPoints     Int                  @default(0)
  totalPosts         Int                  @default(0)
  violations         Int                  @default(0)
  createdAt          DateTime             @default(now())
  lastLogin          DateTime?
  passwordHash       String
  refreshToken       String?
  
  // Настройки приватности
  showPhone          Boolean              @default(false)
  showEmail          Boolean              @default(false)
  showCity           Boolean              @default(false)
  
  // Поля для похвал
  praisesGiven      Praise[]      @relation("PraiseFromUser")  // Похвалы, которые дал пользователь
  praisesReceived   Praise[]      @relation("PraiseToUser")    // Похвалы, которые получил пользователь
  praisesCount      Int           @default(0)                  // Счетчик полученных похвал для быстрого доступа
  
  // Поля для библиотеки
  createdSections   librarySection[]     @relation("section_creator")      // Созданные стеллажи
  editedSections    librarySection[]     @relation("section_last_editor")  // Отредактированные стеллажи
  deletedSections   librarySection[]     @relation("section_deleter")      // Удаленные стеллажи
  
  createdSubsections librarySubsection[] @relation("subsection_creator")   // Созданные подразделы
  editedSubsections  librarySubsection[] @relation("subsection_last_editor") // Отредактированные подразделы
  deletedSubsections librarySubsection[] @relation("subsection_deleter")   // Удаленные подразделы
  
  createdItems       libraryItem[]       @relation("item_creator")         // Созданные документы
  editedItems        libraryItem[]       @relation("item_last_editor")     // Отредактированные документы
  deletedItems       libraryItem[]       @relation("item_deleter")         // Удаленные документы
  
  // Связи
  admin_logs         admin_logs[]
  content            content[]
  rating_adjustments rating_adjustments[]
  setting            setting?
  ruleAcceptance     ruleAcceptance?
  marketItems        marketItem[]
  marketMessagesFrom marketMessage[]      @relation("messages_from")
  marketMessagesTo   marketMessage[]      @relation("messages_to")
  
  userNotifications  UserNotification[]
  notificationSetting NotificationSetting?
  
  likes              Like[]
  comments           Comment[]
}

enum NotificationType {
  LIKE
  COMMENT
  MESSAGE
  SYSTEM
  ACHIEVEMENT
}

enum ContentStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  BLOCKED
}

enum ContentType {
  PROJECT
  MARKET
  HELP
  LIBRARY
}

enum TargetType {
  USER
  POST
  RATING
  SYSTEM
  CONTENT
  LIBRARY_SECTION
  LIBRARY_SUBSECTION
  LIBRARY_ITEM
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum ItemType {
  SELL
  BUY
  FREE
  EXCHANGE
  AUCTION
}

enum DurationType {
  TWOWEEKS
  ONEMONTH
  TWOMONTHS
}

enum ItemCategory {
  TOOLS
  MATERIALS
  FURNITURE
  ELECTRONICS
  COOKING
  AUTO
  SPORT
  ROBOT
  HANDMADE
  STOLAR
  HAMMER
  OTHER
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum ModerationFlag {
  BAD_WORDS
  SPAM_LINKS
  ALL_CAPS
  REPETITIVE_CHARS
}