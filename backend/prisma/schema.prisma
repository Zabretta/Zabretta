// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model admin_logs {
  id         String     @id @default(cuid())
  userId     String
  userName   String
  action     String
  targetType TargetType
  targetId   String?
  details    Json?
  ip         String?
  timestamp  DateTime   @default(now())
  users      users      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model content {
  id          String        @id @default(cuid())
  userId      String
  type        ContentType
  title       String
  description String?
  category    String?
  status      ContentStatus @default(ACTIVE)
  views       Int           @default(0)
  likes       Int           @default(0)
  comments    Int           @default(0)
  rating      Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  users       users         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  likeRecords   Like[]
  commentRecords Comment[]
  praises       Praise[]      // 👈 Добавлена связь с похвалами

  @@map("content")
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  createdAt DateTime @default(now())

  user   users   @relation(fields: [userId], references: [id], onDelete: Cascade)
  content content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId])
  @@index([contentId])
  @@map("likes")
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    users   @relation(fields: [userId], references: [id], onDelete: Cascade)
  content content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([contentId])
  @@index([createdAt])
  @@map("comments")
}

// 👇 НОВАЯ МОДЕЛЬ ПОХВАЛ
model Praise {
  id          String        @id @default(cuid())
  fromUserId  String        @map("from_user_id")
  toUserId    String        @map("to_user_id")
  contentId   String?       @map("content_id")     // За какой контент (проект, пост и т.д.)
  praiseType  PraiseType    @map("praise_type")    // Тип похвалы (great, excellent, master...)
  message     String?                              // Дополнительный текст
  createdAt   DateTime      @default(now())        @map("created_at")

  // Связи
  fromUser    users         @relation("PraiseFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      users         @relation("PraiseToUser", fields: [toUserId], references: [id], onDelete: Cascade)
  content     content?      @relation(fields: [contentId], references: [id], onDelete: SetNull)

  // Уникальность: один пользователь может похвалить конкретный контент только один раз
  @@unique([fromUserId, contentId])
  // Индексы для быстрого поиска
  @@index([fromUserId])
  @@index([toUserId])
  @@index([contentId])
  @@index([createdAt])
  
  @@map("praises")
}

// 👇 НОВЫЙ ENUM ДЛЯ ТИПОВ ПОХВАЛ
enum PraiseType {
  GREAT         // 👍 Молодец!
  EXCELLENT     // 👏 Отличная работа!
  MASTER        // 🔨 Мастер золотые руки!
  INSPIRING     // 💫 Вдохновляет!
  CREATIVE      // 🎨 Креативно!
  DETAILED      // 🔍 Детально проработано
  HELPFUL       // 🤝 Полезный совет
  THANKS        // 🙏 Спасибо!
}

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("user_notifications")
}

model NotificationSetting {
  id        String   @id @default(cuid())
  userId    String   @unique
  
  emailEnabled   Boolean @default(true)
  emailLikes     Boolean @default(true)
  emailComments  Boolean @default(true)
  emailMessages  Boolean @default(true)
  
  pushEnabled    Boolean @default(false)
  pushLikes      Boolean @default(true)
  pushComments   Boolean @default(true)
  pushMessages   Boolean @default(true)
  
  siteLikes      Boolean @default(true)
  siteComments   Boolean @default(true)
  siteMessages   Boolean @default(true)
  
  quietHours     Boolean @default(false)
  quietStart     Int?
  quietEnd       Int?
  
  updatedAt      DateTime @updatedAt
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

model rating_adjustments {
  id             String   @id @default(cuid())
  userId         String
  reason         String
  ratingChange   Int
  activityChange Int
  adminId        String?
  adminNote      String?
  timestamp      DateTime @default(now())
  users          users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model setting {
  id              String   @id @default(cuid())
  userId          String   @unique
  theme           String   @default("auto")
  brightness      Int      @default(100)
  fontSize        Int      @default(100)
  showAnimations  Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  users users @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("settings")
}

model rule {
  id          String   @id @default(cuid())
  text        String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("rules")
}

model ruleAcceptance {
  id          String   @id @default(cuid())
  userId      String   @unique
  acceptedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rule_acceptances")
}

model marketItem {
  id             String        @id @default(cuid())
  title          String
  description    String
  price          String
  priceValue     Int?
  location       String
  author         String
  authorId       String
  rating         Float         @default(4.5)
  type           ItemType
  imageUrl       String?
  negotiable     Boolean       @default(false)
  expirationDate DateTime?
  duration       DurationType?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  views          Int           @default(0)
  contacts       Int           @default(0)
  category       ItemCategory?
  categoryId     String?
  
  // ПОЛЯ ДЛЯ МОДЕРАЦИИ
  moderationStatus ModerationStatus @default(PENDING)
  moderationFlags  ModerationFlag[] @default([])
  moderatedAt      DateTime?
  moderatedBy      String?
  moderatorNote    String?

  // 👇 НОВЫЕ ПОЛЯ ДЛЯ РЕДАКТИРОВАНИЯ И УДАЛЕНИЯ
  editCount        Int              @default(0)      // Счетчик редактирований
  lastEditedAt     DateTime?                          // Дата последнего редактирования
  isDeleted        Boolean          @default(false)   // Мягкое удаление
  deletedAt        DateTime?                          // Дата удаления

  users        users           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  marketCategory marketCategory? @relation(fields: [categoryId], references: [id])
  messages     marketMessage[]

  @@map("market_items")
}

model marketCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  icon        String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items marketItem[]

  @@map("market_categories")
}

model marketMessage {
  id         String   @id @default(cuid())
  parentId   String?  
  itemId     String
  fromUserId String
  toUserId   String
  message    String
  read       Boolean  @default(false)
  contactMethod String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt @default(now())

  // Связи
  item     marketItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fromUser users @relation("messages_from", fields: [fromUserId], references: [id])
  toUser   users @relation("messages_to", fields: [toUserId], references: [id])
  
  // Для древовидных ответов
  parent   marketMessage? @relation("MessageReplies", fields: [parentId], references: [id])
  replies  marketMessage[] @relation("MessageReplies")

  // Индексы
  @@index([itemId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([createdAt])
  @@index([parentId])
  
  @@map("market_messages")
}

model users {
  id                 String               @id @default(cuid())
  login              String               @unique
  email              String               @unique
  name               String?
  avatar             String?
  bio                String?
  location           String?
  phone              String?
  role               UserRole             @default(USER)
  isActive           Boolean              @default(true)
  rating             Int                  @default(0)
  activityPoints     Int                  @default(0)
  totalPosts         Int                  @default(0)
  violations         Int                  @default(0)
  createdAt          DateTime             @default(now())
  lastLogin          DateTime?
  passwordHash       String
  refreshToken       String?
  
  // Настройки приватности
  showPhone          Boolean              @default(false)
  showEmail          Boolean              @default(false)
  showCity           Boolean              @default(false)
  
  // 👇 ДОБАВЛЕНЫ ПОЛЯ ДЛЯ ПОХВАЛ
  praisesGiven      Praise[]      @relation("PraiseFromUser")  // Похвалы, которые дал пользователь
  praisesReceived   Praise[]      @relation("PraiseToUser")    // Похвалы, которые получил пользователь
  praisesCount      Int           @default(0)                  // Счетчик полученных похвал для быстрого доступа
  
  // Связи
  admin_logs         admin_logs[]
  content            content[]
  rating_adjustments rating_adjustments[]
  setting            setting?
  ruleAcceptance     ruleAcceptance?
  marketItems        marketItem[]
  marketMessagesFrom marketMessage[]      @relation("messages_from")
  marketMessagesTo   marketMessage[]      @relation("messages_to")
  
  userNotifications  UserNotification[]
  notificationSetting NotificationSetting?
  
  likes              Like[]
  comments           Comment[]
}

enum NotificationType {
  LIKE
  COMMENT
  MESSAGE
  SYSTEM
  ACHIEVEMENT
}

enum ContentStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  BLOCKED
}

enum ContentType {
  PROJECT
  MARKET
  HELP
  LIBRARY
}

enum TargetType {
  USER
  POST
  RATING
  SYSTEM
  CONTENT
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum ItemType {
  SELL
  BUY
  FREE
  EXCHANGE
  AUCTION
}

enum DurationType {
  TWOWEEKS
  ONEMONTH
  TWOMONTHS
}

enum ItemCategory {
  TOOLS
  MATERIALS
  FURNITURE
  ELECTRONICS
  COOKING
  AUTO
  SPORT
  ROBOT
  HANDMADE
  STOLAR
  HAMMER
  OTHER
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum ModerationFlag {
  BAD_WORDS
  SPAM_LINKS
  ALL_CAPS
  REPETITIVE_CHARS
}